# =============================================================================
# IDMAS 环境变量配置模板
# 复制此文件为 .env 并填入实际值，.env 已被 .gitignore 忽略
# 生产环境使用 HashiCorp Vault 管理密钥
# =============================================================================

# --- 数据库 ---
# DATABASE_URL=postgresql+asyncpg://idmas:password@localhost:5432/idmas

# --- Redis ---
# REDIS_URL=redis://localhost:6379/0

# --- vLLM推理服务 ---
# VLLM_URL=http://localhost:8000
# VLLM_MODEL=qwen2.5-vl-7b-finetuned
# VLLM_MAX_TOKENS=2048

# --- PaddleOCR ---
# OCR_URL=http://localhost:8100

# --- Milvus向量库 ---
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# --- Neo4j图数据库 ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# --- Elasticsearch ---
# ES_URL=http://localhost:9200

# --- MinIO对象存储 ---
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=idmas-drawings

# --- RabbitMQ消息队列 ---
# RABBITMQ_URL=amqp://idmas:password@localhost:5672

# --- JWT认证 ---
# JWT_PRIVATE_KEY_PATH=/path/to/private.pem
# JWT_PUBLIC_KEY_PATH=/path/to/public.pem
# JWT_ALGORITHM=RS256
# JWT_EXPIRE_MINUTES=60

# --- 可观测性 ---
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- 应用配置 ---
# APP_ENV=development
# APP_DEBUG=true
# APP_LOG_LEVEL=INFO
# APP_CORS_ORIGINS=http://localhost:3000
