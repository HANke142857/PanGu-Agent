# =============================================================================
# Docker Compose 环境变量模板
# 默认值已写在 docker-compose.yml 内，本文件仅用于覆盖（复制为 .env）。
# =============================================================================

# 凭据（生产务必修改）
# POSTGRES_PASSWORD=idmas_pwd
# RABBITMQ_DEFAULT_PASS=idmas_pwd
# MINIO_ROOT_PASSWORD=minioadmin
# NEO4J_PASSWORD=idmas_neo4j

# 后端开关（默认见 compose）：
# LLM_BACKEND=fake          # 改 vllm 需 GPU + 独立 vLLM 服务
# OCR_BACKEND=fake          # 改 paddle 需 PaddleOCR 服务
# PLM_BACKEND=fake          # 改 real 需配 PLM_*_URL / PLM_AUTH_TOKEN
# VECTOR_BACKEND=milvus     # 改 memory 则无需外部 Milvus

# 向量库（默认复用宿主机 milvus-standalone）
# MILVUS_HOST=host.docker.internal
# MILVUS_PORT=19530
