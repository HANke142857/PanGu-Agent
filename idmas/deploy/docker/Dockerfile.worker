# =============================================================================
# LangGraph Worker 镜像。
# 消费 RabbitMQ task.created，驱动 Master Graph 并回写结果。无 HTTP 端口。
# 构建上下文为仓库根目录（含 idmas/ 包）。
# =============================================================================
FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app

WORKDIR /app

COPY idmas/requirements.txt /app/idmas/requirements.txt
RUN pip install --no-cache-dir -r /app/idmas/requirements.txt

COPY idmas /app/idmas

RUN useradd -m appuser && chown -R appuser /app
USER appuser

CMD ["python", "-m", "idmas.worker"]
