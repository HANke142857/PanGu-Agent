# =============================================================================
# FastAPI 应用镜像。
# 构建上下文为仓库根目录（含 idmas/ 包）。多阶段 + 非 root + 健康检查。
# =============================================================================
FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app

WORKDIR /app

# 先装依赖（利用层缓存）
COPY idmas/requirements.txt /app/idmas/requirements.txt
RUN pip install --no-cache-dir -r /app/idmas/requirements.txt

# 再拷源码
COPY idmas /app/idmas

# 非 root 运行
RUN useradd -m appuser && chown -R appuser /app
USER appuser

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
    CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8080/api/v1/health').status==200 else 1)"

CMD ["uvicorn", "idmas.main:app", "--host", "0.0.0.0", "--port", "8080"]
