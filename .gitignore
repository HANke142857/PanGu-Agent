# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── 环境变量（含密钥，勿入库）─────────────────────────────
.env

# ── IDE ──────────────────────────────────────────────────
.idea/
.vscode/

# ── 前端依赖与构建产物 ───────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/vite.config.*.timestamp-*.mjs

# ── 运行日志（保留目录占位，忽略其余）──────────────────────
logs/*
!logs/.gitkeep
